<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="NotaPenjualan" language="groovy" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="d14ce1aa-1216-4793-88a4-984fc0f3ba30">
	
    <parameter name="id_nota" class="java.lang.String"/>

    <queryString language="SQL">
		<![CDATA[SELECT
    n.idnota,
    n.tanggal,
    p.id,
    p.nmplgn,
    p.telp,
    p.alamat,
    k.id_kasir,
    k.nama_kasir,
    b.kdbrg,
    b.nmbrg,
    b.jenis,
    i.hargabeli,
    i.hargajual,
    i.qty,
    (i.qty * i.hargajual) AS subtotal
FROM nota n
INNER JOIN pelanggan p ON n.idpelanggan = p.id
INNER JOIN kasir1 k ON n.idkasir = k.id_kasir
INNER JOIN isi i ON n.idnota = i.idnota
INNER JOIN barang1 b ON i.kdbrg = b.kdbrg
WHERE n.idnota = $P{id_nota}
ORDER BY n.idnota, b.nmbrg]]>
    </queryString>
	
    <field name="idnota" class="java.lang.String"/>
    <field name="tanggal" class="java.sql.Date"/>
    <field name="id" class="java.lang.String"/>
    <field name="nmplgn" class="java.lang.String"/>
    <field name="telp" class="java.lang.String"/>
    <field name="alamat" class="java.lang.String"/>
    <field name="id_kasir" class="java.lang.String"/>
    <field name="nama_kasir" class="java.lang.String"/>
    <field name="kdbrg" class="java.lang.String"/>
    <field name="nmbrg" class="java.lang.String"/>
    <field name="jenis" class="java.lang.String"/>
    <field name="hargabeli" class="java.lang.Integer"/>
    <field name="hargajual" class="java.lang.Integer"/>
    <field name="qty" class="java.lang.Integer"/>
    <field name="subtotal" class="java.lang.Long"/>
	
    <variable name="variable1" class="java.lang.Long" calculation="Sum">
        <variableExpression><![CDATA[$F{subtotal}]]></variableExpression>
    </variable>
	
    <group name="idnota">
        <groupExpression><![CDATA[$F{idnota}]]></groupExpression>
    </group>
	
